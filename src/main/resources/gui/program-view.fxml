<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="code.gui.ProgramController">
   <children>
      <VBox layoutX="250.0" layoutY="100.0" prefHeight="200.0" prefWidth="100.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <TextField fx:id="prgCountField" alignment="CENTER" editable="false" text="Program ID Count: " />
            <ListView fx:id="prgIdList" prefHeight="70.0" prefWidth="600.0">
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" />
               </padding>
            </ListView>
            <HBox prefHeight="306.0" prefWidth="600.0" VBox.vgrow="ALWAYS">
               <children>
                  <VBox alignment="CENTER" prefHeight="306.0" prefWidth="200.0" HBox.hgrow="ALWAYS">
                     <children>
                        <Label alignment="CENTER" maxWidth="1.7976931348623157E308" prefHeight="18.0" prefWidth="186.0" text="ExeStack" VBox.vgrow="ALWAYS" />
                        <ListView fx:id="exeStackList" prefHeight="300.0" prefWidth="162.0" VBox.vgrow="ALWAYS" />
                     </children>
                  </VBox>
                  <VBox alignment="CENTER" prefHeight="306.0" prefWidth="340.0" HBox.hgrow="ALWAYS">
                     <children>
                        <Label alignment="CENTER" maxWidth="1.7976931348623157E308" prefHeight="18.0" prefWidth="290.0" text="Symbols Table" VBox.vgrow="ALWAYS" />
                        <TableView fx:id="symTable" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="109.0" prefWidth="340.0" VBox.vgrow="ALWAYS">
                          <columns>
                            <TableColumn fx:id="symNameCol" maxWidth="1.7976931348623157E308" prefWidth="500.0" text="VarName" />
                            <TableColumn fx:id="symValueCol" maxWidth="1.7976931348623157E308" prefWidth="500.0" text="Value" />
                          </columns>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                        <Label alignment="CENTER" maxWidth="1.7976931348623157E308" prefHeight="18.0" prefWidth="311.0" text="Heap Table" VBox.vgrow="ALWAYS" />
                        <TableView fx:id="heapTable" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="102.0" prefWidth="277.0" VBox.vgrow="ALWAYS">
                          <columns>
                            <TableColumn fx:id="heapAddressCol" maxWidth="1.7976931348623157E308" prefWidth="500.0" text="Address" />
                            <TableColumn fx:id="heapValueCol" maxWidth="1.7976931348623157E308" prefWidth="500.0" text="Value" />
                          </columns>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                        <Label alignment="CENTER" maxWidth="1.7976931348623157E308" text="File Table" />
                        <ListView fx:id="fileTable" maxHeight="1.7976931348623157E308" prefHeight="87.0" prefWidth="277.0" VBox.vgrow="ALWAYS" />
                        <Button fx:id="runOneStepButton" alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" onAction="#onOneStep" text="One Step" textAlignment="CENTER" VBox.vgrow="ALWAYS" />
                     </children>
                  </VBox>
                  <VBox alignment="CENTER" prefHeight="306.0" prefWidth="200.0" HBox.hgrow="ALWAYS">
                     <children>
                        <Label alignment="CENTER" contentDisplay="CENTER" maxWidth="1.7976931348623157E308" prefHeight="18.0" prefWidth="180.0" text="Output" textAlignment="CENTER" VBox.vgrow="ALWAYS" />
                        <ListView fx:id="outList" prefHeight="288.0" prefWidth="200.0" VBox.vgrow="ALWAYS" />
                     </children>
                  </VBox>
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
